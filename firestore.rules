rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Is the caller an admin? True if their email is the bootstrap owner, OR
    // they have a doc in the admins collection (added manually via the Console).
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'leightonbailey4523@gmail.com'
        || exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // ── DM safety helpers (friends-only + block enforcement, server-side) ──
    // In a 2-person DM, return the OTHER participant (not me).
    function dmPeer(parts) {
      return parts[0] == request.auth.uid ? parts[1] : parts[0];
    }
    // Has `other` added me as a friend? (friends are mirrored to the public profile)
    function peerAddedMe(other) {
      return exists(/databases/$(database)/documents/profiles/$(other))
        && request.auth.uid in get(/databases/$(database)/documents/profiles/$(other)).data.get('friends', []);
    }
    // Has `other` blocked me? (blocked list lives on their private user doc; rules can still read it)
    function peerBlockedMe(other) {
      return exists(/databases/$(database)/documents/users/$(other))
        && request.auth.uid in get(/databases/$(database)/documents/users/$(other)).data.get('blocked', []);
    }
    // I may DM these participants only if it's a 2-person chat, the other person has
    // added me as a friend, and they haven't blocked me.
    function canDM(parts) {
      return parts.size() == 2
        && peerAddedMe(dmPeer(parts))
        && !peerBlockedMe(dmPeer(parts));
    }

    // Admin allowlist. A doc here (id = the admin's uid) grants admin powers.
    // Only the owner of that uid (or an existing admin) can read it; nobody can
    // write from a client — add/remove admins in the Firebase Console only.
    match /admins/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if false;
    }

    // Each user can only read/write their OWN profile/save document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Public mini-profiles (name, major) so signed-in users can find & add each other.
    match /profiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Direct messages — only the two participants can see a conversation, and you
    // can only start/continue one with someone who has added you as a friend
    // (and hasn't blocked you). Reading existing history stays open to participants.
    match /dms/{convoId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.participants;
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.participants
                    && canDM(resource.data.participants);
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participants
                    && canDM(request.resource.data.participants);

      match /messages/{msgId} {
        // Only the conversation's participants can read its messages.
        allow read: if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/dms/$(convoId)).data.participants;
        // Send only as yourself, in a chat you're part of, to someone who added you
        // (and hasn't blocked you), with a non-empty message under 2,000 characters.
        allow create: if request.auth != null
                      && request.resource.data.senderId == request.auth.uid
                      && request.auth.uid in get(/databases/$(database)/documents/dms/$(convoId)).data.participants
                      && canDM(get(/databases/$(database)/documents/dms/$(convoId)).data.participants)
                      && request.resource.data.text is string
                      && request.resource.data.text.size() > 0
                      && request.resource.data.text.size() <= 2000;
      }
    }

    // Shared campus feed — everyone signed in can see all posts.
    match /posts/{postId} {
      // Anyone signed in can read the feed.
      allow read: if request.auth != null;

      // You can only create a post as yourself (uid must match your account),
      // and the post text must be a string under 2,000 characters.
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.get('text', '') is string
                    && request.resource.data.get('text', '').size() <= 2000;

      // The author/admin can edit the whole post; everyone else can change ONLY
      // the likedBy + comments arrays (so liking/commenting works) — they can't
      // touch the post's text, author, or anything else.
      allow update: if request.auth != null && (
                      resource.data.uid == request.auth.uid || isAdmin()
                      || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy', 'comments'])
                    );

      // The original author can delete their own post; admins can remove any post.
      allow delete: if request.auth != null
                    && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // Content reports — any signed-in user can flag content (as themselves).
    // Only admins can read, resolve, or delete reports.
    match /reports/{reportId} {
      allow create: if request.auth != null
                    && request.resource.data.reportedBy == request.auth.uid
                    && request.resource.data.status == 'open';
      allow read, update, delete: if isAdmin();
    }

    // Suspensions — a bans/{uid} doc blocks that account. Only admins can write;
    // a user (or admin) can read their own ban so the app can enforce it at login.
    match /bans/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }

    // Ad campaigns — advertisers create/manage their own; everyone signed in can read
    // (so the feed can show sponsored cards and the admin can total revenue);
    // an advertiser edits their own, admins can moderate any.
    match /campaigns/{campaignId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.createdBy == request.auth.uid;
      // advertiser/admin can edit anything; any viewer can bump ONLY the ad
      // counters (impressions/clicks) as sponsored cards are shown/tapped
      allow update: if request.auth != null && (
                      resource.data.createdBy == request.auth.uid || isAdmin()
                      || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['impressions', 'clicks'])
                    );
      allow delete: if request.auth != null
                    && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    // Campus events — everyone signed in can see them; you create as yourself;
    // the creator can edit/remove their own, admins can moderate any.
    match /events/{eventId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.createdBy == request.auth.uid;
      // creator/admin can edit anything; anyone signed in can change ONLY the attendees
      // list (so members can check in / out of an event)
      allow update: if request.auth != null && (
                      resource.data.createdBy == request.auth.uid || isAdmin()
                      || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['attendees'])
                    );
      allow delete: if request.auth != null
                    && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    // Student-listed clubs — everyone signed in can browse them; you create as yourself.
    match /clubs/{clubId} {
      // Anyone signed in can see the clubs on any campus.
      allow read: if request.auth != null;

      // You can only list a club as yourself (createdBy must match your account).
      allow create: if request.auth != null
                    && request.resource.data.createdBy == request.auth.uid;

      // The student who listed the club can edit/remove it; admins can moderate any club.
      allow update, delete: if request.auth != null
                            && (resource.data.createdBy == request.auth.uid || isAdmin());

      // Club announcements — any signed-in user can read; only the club's officer
      // (its creator) or an admin can post/edit/remove them.
      match /announcements/{annId} {
        allow read: if request.auth != null;
        allow create, update, delete: if request.auth != null && (
          get(/databases/$(database)/documents/clubs/$(clubId)).data.createdBy == request.auth.uid
          || isAdmin()
        );
      }
    }

    // Campus job board — anyone signed in can browse jobs; you post as yourself;
    // the poster/admin can edit or remove. Applications (with résumés) are private:
    // only the applicant and the job's poster can read them.
    match /jobs/{jobId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.createdBy == request.auth.uid
                    && request.resource.data.title is string
                    && request.resource.data.title.size() <= 200;
      allow update, delete: if request.auth != null
                            && (resource.data.createdBy == request.auth.uid || isAdmin());

      match /applications/{appId} {
        // a student submits their own application; can't apply as someone else
        allow create: if request.auth != null
                      && request.resource.data.studentUid == request.auth.uid;
        // only the applicant, the job's poster, or an admin can read an application
        allow read: if request.auth != null && (
          resource.data.studentUid == request.auth.uid
          || get(/databases/$(database)/documents/jobs/$(jobId)).data.createdBy == request.auth.uid
          || isAdmin()
        );
        allow update, delete: if isAdmin();
      }
    }
  }
}
