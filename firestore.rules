rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Is the caller an admin? True if their email is the bootstrap owner, OR
    // they have a doc in the admins collection (added manually via the Console).
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'leightonbailey4523@gmail.com'
        || exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // Admin allowlist. A doc here (id = the admin's uid) grants admin powers.
    // Only the owner of that uid (or an existing admin) can read it; nobody can
    // write from a client — add/remove admins in the Firebase Console only.
    match /admins/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if false;
    }

    // Each user can only read/write their OWN profile/save document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Public mini-profiles (name, major) so signed-in users can find & add each other.
    match /profiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Direct messages — only the two participants can see/use a conversation.
    match /dms/{convoId} {
      allow read, update: if request.auth != null && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;

      match /messages/{msgId} {
        // Only the conversation's participants can read its messages.
        allow read: if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/dms/$(convoId)).data.participants;
        // You can only send a message as yourself, in a conversation you're part of.
        allow create: if request.auth != null
                      && request.resource.data.senderId == request.auth.uid
                      && request.auth.uid in get(/databases/$(database)/documents/dms/$(convoId)).data.participants;
      }
    }

    // Shared campus feed — everyone signed in can see all posts.
    match /posts/{postId} {
      // Anyone signed in can read the feed.
      allow read: if request.auth != null;

      // You can only create a post as yourself (uid must match your account).
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;

      // Anyone signed in can update a post (needed for likes + comments).
      allow update: if request.auth != null;

      // The original author can delete their own post; admins can remove any post.
      allow delete: if request.auth != null
                    && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // Content reports — any signed-in user can flag content (as themselves).
    // Only admins can read, resolve, or delete reports.
    match /reports/{reportId} {
      allow create: if request.auth != null
                    && request.resource.data.reportedBy == request.auth.uid
                    && request.resource.data.status == 'open';
      allow read, update, delete: if isAdmin();
    }

    // Suspensions — a bans/{uid} doc blocks that account. Only admins can write;
    // a user (or admin) can read their own ban so the app can enforce it at login.
    match /bans/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }

    // Ad campaigns — advertisers create/manage their own; everyone signed in can read
    // (so the feed can show sponsored cards and the admin can total revenue);
    // an advertiser edits their own, admins can moderate any.
    match /campaigns/{campaignId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if request.auth != null
                            && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    // Student-listed clubs — everyone signed in can browse them; you create as yourself.
    match /clubs/{clubId} {
      // Anyone signed in can see the clubs on any campus.
      allow read: if request.auth != null;

      // You can only list a club as yourself (createdBy must match your account).
      allow create: if request.auth != null
                    && request.resource.data.createdBy == request.auth.uid;

      // The student who listed the club can edit/remove it; admins can moderate any club.
      allow update, delete: if request.auth != null
                            && (resource.data.createdBy == request.auth.uid || isAdmin());
    }
  }
}
