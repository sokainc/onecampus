{
  "expo": {
    "name": "One Campus",
    "slug": "onecampus-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#15131F"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo-icon.png",
        "backgroundColor": "#15131F"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/logo-icon.png"
    },
    "plugins": [
      ["expo-location", { "locationWhenInUsePermission": "One Campus uses your location to show your spot on the campus map and give walking directions." }]
    ],
    "extra": {
      "eas": {
        "projectId": "9c104cf3-538a-4a62-993d-018c35693c9a"
      }
    },
    "owner": "one-campus",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/9c104cf3-538a-4a62-993d-018c35693c9a"
    }
  }
}
